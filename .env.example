# Shared
NODE_ENV=development

# Web
NEXT_PUBLIC_APP_NAME=FreeVibes 2.0
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API
API_PORT=3001
WEB_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# Development placeholders. Replace them with strong secrets before any real deployment.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
REFRESH_TOKEN_COOKIE_NAME=freevibes_refresh_token
LOCAL_STORAGE_BASE_URL=http://localhost:3001/uploads
COOKIE_SECURE=false
# Optional override if you want to point the seed to an external legacy dataset.
# LEGACY_ROOT=

# Database
DATABASE_URL=postgresql://freevibes:freevibes@postgres:5432/freevibes
POSTGRES_DB=freevibes
POSTGRES_USER=freevibes
POSTGRES_PASSWORD=freevibes
SEED_FORCE_RESET=false

# Redis
REDIS_URL=redis://redis:6379
