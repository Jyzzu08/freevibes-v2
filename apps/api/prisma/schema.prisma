generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum StorageProvider {
  LOCAL
  S3
}

enum AssetKind {
  IMAGE
  AUDIO
  AVATAR
}

enum SourceType {
  HOME
  BROWSE
  SEARCH
  ALBUM
  PLAYLIST
  ARTIST
  LIBRARY
  UNKNOWN
}

model Role {
  id        String   @id @default(cuid())
  key       RoleKey  @unique
  name      String
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  username        String            @unique
  passwordHash    String
  roleId          String
  status          AccountStatus     @default(ACTIVE)
  role            Role              @relation(fields: [roleId], references: [id])
  profile         Profile?
  playlists       Playlist[]
  favoriteTracks  FavoriteTrack[]
  savedAlbums     SavedAlbum[]
  followedArtists FollowedArtist[]
  playbackHistory PlaybackHistory[]
  recentlyPlayed  RecentlyPlayed[]
  refreshTokens   RefreshToken[]
  uploadedAssets  UploadedAsset[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Profile {
  id            String         @id @default(cuid())
  userId        String         @unique
  displayName   String
  bio           String?
  avatarAssetId String?
  country       String?
  birthDate     DateTime?
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarAsset   UploadedAsset? @relation("ProfileAvatar", fields: [avatarAssetId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Genre {
  id           String         @id @default(cuid())
  name         String         @unique
  slug         String         @unique
  description  String?
  coverAssetId String?
  artists      Artist[]
  albums       Album[]
  tracks       Track[]
  coverAsset   UploadedAsset? @relation("GenreCover", fields: [coverAssetId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Artist {
  id          String         @id @default(cuid())
  name        String         @unique
  slug        String         @unique
  bio         String?
  country     String?
  formedYear  Int?
  genreId     String
  heroAssetId String?
  genre       Genre          @relation(fields: [genreId], references: [id])
  heroAsset   UploadedAsset? @relation("ArtistHero", fields: [heroAssetId], references: [id])
  albums      Album[]
  tracks      Track[]
  followers   FollowedArtist[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([genreId])
}

model Album {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  description  String?
  artistId     String
  genreId      String
  releaseDate  DateTime?
  coverAssetId String?
  artist       Artist         @relation(fields: [artistId], references: [id])
  genre        Genre          @relation(fields: [genreId], references: [id])
  coverAsset   UploadedAsset? @relation("AlbumCover", fields: [coverAssetId], references: [id])
  tracks       Track[]
  savedBy      SavedAlbum[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([artistId, releaseDate])
  @@index([genreId])
  @@unique([artistId, title])
}

model Track {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  trackNumber  Int
  durationSec  Int
  artistId     String
  albumId      String
  genreId      String
  audioAssetId String?
  isPublished  Boolean        @default(true)
  artist       Artist         @relation(fields: [artistId], references: [id])
  album        Album          @relation(fields: [albumId], references: [id])
  genre        Genre          @relation(fields: [genreId], references: [id])
  audioAsset   UploadedAsset? @relation("TrackAudio", fields: [audioAssetId], references: [id])
  favorites    FavoriteTrack[]
  playlistRows PlaylistTrack[]
  history      PlaybackHistory[]
  recent       RecentlyPlayed[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([albumId, trackNumber])
  @@index([albumId])
  @@index([artistId])
  @@index([genreId])
}

model Playlist {
  id           String         @id @default(cuid())
  userId       String
  title        String
  slug         String
  description  String?
  coverAssetId String?
  isPublic     Boolean        @default(false)
  user         User           @relation(fields: [userId], references: [id])
  coverAsset   UploadedAsset? @relation("PlaylistCover", fields: [coverAssetId], references: [id])
  tracks       PlaylistTrack[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([slug])
  @@index([userId])
  @@index([userId, updatedAt])
  @@index([isPublic, updatedAt])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([playlistId, trackId])
  @@unique([playlistId, position])
}

model FavoriteTrack {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, trackId])
  @@index([userId, createdAt])
}

model SavedAlbum {
  id        String   @id @default(cuid())
  userId    String
  albumId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, albumId])
  @@index([userId, createdAt])
}

model FollowedArtist {
  id        String   @id @default(cuid())
  userId    String
  artistId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
  @@index([userId, createdAt])
}

model PlaybackHistory {
  id              String     @id @default(cuid())
  userId          String
  trackId         String
  sourceType      SourceType @default(UNKNOWN)
  sourceId        String?
  playedAt        DateTime   @default(now())
  completed       Boolean    @default(false)
  progressSeconds Int?
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           Track      @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
  @@index([userId, trackId, playedAt])
}

model RecentlyPlayed {
  id           String   @id @default(cuid())
  userId       String
  trackId      String
  lastPlayedAt DateTime @default(now())
  playCount    Int      @default(1)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track        Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId, lastPlayedAt])
}

model UploadedAsset {
  id             String          @id @default(cuid())
  kind           AssetKind
  provider       StorageProvider @default(LOCAL)
  originalName   String
  storagePath    String
  publicUrl      String
  mimeType       String
  sizeBytes      Int
  checksum       String?
  ownerType      String?
  ownerId        String?
  uploadedById   String?
  uploadedBy     User?           @relation(fields: [uploadedById], references: [id])
  profileAvatars Profile[]       @relation("ProfileAvatar")
  genreCovers    Genre[]         @relation("GenreCover")
  artistHeroes   Artist[]        @relation("ArtistHero")
  albumCovers    Album[]         @relation("AlbumCover")
  trackAudios    Track[]         @relation("TrackAudio")
  playlistCovers Playlist[]      @relation("PlaylistCover")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ownerType, ownerId])
  @@index([kind, createdAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
}
