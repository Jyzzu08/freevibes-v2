{
  "name": "freevibes-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "pnpm --filter @freevibes/api prisma generate",
    "db:migrate": "pnpm --filter @freevibes/api prisma migrate dev",
    "db:seed": "pnpm --filter @freevibes/api prisma db seed",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "2.8.17"
  }
}

